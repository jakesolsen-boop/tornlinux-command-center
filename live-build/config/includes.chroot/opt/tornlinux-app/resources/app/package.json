{
  "name": "tornlinux-deployment-ready-project",
  "version": "1.3.14",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build:renderer": "vite build",
    "preview:renderer": "vite preview",
    "package:linux": "npm run build:renderer && npx electron-packager . TornLinux --platform=linux --arch=x64 --overwrite --prune=true --ignore='^(?:/src/shared|/specs|/config|/scripts|/live-build|/tsconfig.json|/vite.config.ts|/README.md)$'",
    "prepare:live-build": "bash scripts/prepare-live-build.sh",
    "live-build:config": "bash scripts/configure-live-build.sh",
    "live-build:build": "bash scripts/build-iso.sh",
    "preflight": "bash scripts/preflight-check.sh"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron-packager": "^17.1.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "electron": "^31.0.0"
  }
}
